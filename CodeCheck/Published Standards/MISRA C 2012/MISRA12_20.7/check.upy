    return {
        'MISRA12_20.7': 'Published Standards/MISRA C 2012/' + """\
20.7 Expressions resulting from the expansion of macro parameters shall be enclosed in parentheses""",
        'MISRA23_20.7': 'Published Standards/MISRA C 2023/' + """\
20.7 Expressions resulting from the expansion of macro parameters shall be enclosed in parentheses""",
        'MISRA25_20.7': 'Published Standards/MISRA C 2025/' + """\
20.7 Expressions resulting from the expansion of macro parameters shall be appropriately delimited""",
        'CPP_PR044': 'All Checks/Language Specific/C and C++/Preprocessor/' + """\
Expressions resulting from the expansion of macro parameters shall be enclosed in parentheses""",
    }[id]


