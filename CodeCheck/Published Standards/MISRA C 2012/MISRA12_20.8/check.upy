# This script is designed to run with Understand - CodeCheck
# Written by Jason Quinn
# 2026-06-17


ERR1 = 'The controlling expression of #%1 shall evaluate to 0 or 1'


# Backslash + newline: the line-continuation token inside a preprocessor
# directive. It extends the directive across multiple physical lines.
_LINE_CONT = "\\\n"

# Binary operators whose result is essentially Boolean (always 0 or 1):
# logical, equality and relational operators.
_BOOL_OPS = frozenset((
    "||", "&&", "==", "!=", "<", ">", "<=", ">=",
))

# Binary operators, mapped to their C precedence. Lower number == looser
# binding (evaluated last), so the top-level operator with the SMALLEST
# precedence is the one that determines the type of the whole expression's
# result. If that operator is in _BOOL_OPS the expression is Boolean (0 or
# 1); otherwise its value is an unconstrained integer.
_BINARY_PREC = {
    "||": 0,
    "&&": 1,
    "|": 2,
    "^": 3,
    "&": 4,
    "==": 5, "!=": 5,
    "<": 6, ">": 6, "<=": 6, ">=": 6,
    "<<": 7, ">>": 7,
    "+": 8, "-": 8,
    "*": 9, "/": 9, "%": 9,
}

# Multi-character operators, longest first, so the macro-body tokenizer
# matches e.g. "<<" before "<" and "==" before "=".
_MULTI_CHAR_OPS = ("||", "&&", "==", "!=", "<=", ">=", "<<", ">>")

# Guard against pathological self-referential macro chains.
_MAX_MACRO_DEPTH = 16


def ids():
    return ('MISRA12_20.8', 'MISRA23_20.8', 'MISRA25_20.8', 'CPP_PR047')


def name(id):
    title = """\
20.8 The controlling expression of a #if or #elif preprocessing directive shall evaluate to 0 or 1"""
    return {
        'MISRA12_20.8': 'Published Standards/MISRA C 2012/' + title,
        'MISRA23_20.8': 'Published Standards/MISRA C 2023/' + title,
        'MISRA25_20.8': 'Published Standards/MISRA C 2025/' + title,
        'CPP_PR047': 'All Checks/Language Specific/C and C++/Preprocessor/' + """\
The controlling expression of a #if or #elif preprocessing directive shall evaluate to 0 or 1""",
    }[id]


