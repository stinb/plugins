ERR1 = 'Macro parameter "%1" is used in mixed contexts (both as operand of # or ## and elsewhere); the argument passed here is itself a macro and so is subject to further macro replacement'


def ids():
    return ('MISRA12_20.12', 'MISRA23_20.12', 'MISRA25_20.12', 'CPP_PR046')


