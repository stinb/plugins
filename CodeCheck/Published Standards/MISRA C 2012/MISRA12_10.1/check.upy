<td>3</td>
<td>4</td>
<td>5,6</td>
<td>6</td>
<td></td>
<td>1</td>
<td>9</td>
</tr>
<tr>
<td>?:</td>
<td>1st</td>
<td></td>
<td>2</td>
<td>2</td>
<td>2</td>
<td>2</td>
<td>2</td>
<td>2</td>
</tr>
<tr>
<td>?:</td>
<td>2nd and 3rd</td>
<td></td>
<td></td>
<td></td>
<td></td>
