    return {
        'MISRA12_DIR_4.13': 'Published Standards/MISRA C 2012/' + """\
Directive 4.13 Functions which are designed to provide operations on a resource should be called in an appropriate sequence (Partial)""",
        'MISRA23_DIR_4.13': 'Published Standards/MISRA C 2023/' + """\
Directive 4.13 Functions which are designed to provide operations on a resource should be called in an appropriate sequence (Partial)""",
        'MISRA25_DIR_4.13': 'Published Standards/MISRA C 2025/' + """\
Directive 4.13 Functions which are designed to provide operations on a resource should be called in an appropriate sequence (Partial)""",
        'CPP_F074': 'All Checks/Language Specific/C and C++/Functions/' + """\
Functions which are designed to provide operations on a resource should be called in an appropriate sequence (Partial)""",
    }[id]


