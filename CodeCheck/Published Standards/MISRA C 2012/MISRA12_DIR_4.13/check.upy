# This script is designed to run with Understand - CodeCheck
# Written by Jason Quinn
# 2026-06-03


from Modules import refInNode


ERR1 = 'Resource allocated here may not be released on all paths to function exit'

# Allocator:deallocator function pairs that are recognised by default. Each
# allocator returns a resource that is captured in a local object. Projects add
# their own balanced pairs through the option below.
DEFAULT_PAIRS = (
    'fopen:fclose freopen:fclose tmpfile:fclose '
    'popen:pclose opendir:closedir mutex_lock:mutex_unlock'
)

# Node kinds that leave the function other than by normal fall-through. A path
# that leaves through one of these (e.g. an early error return taken when the
# allocation failed) is treated as deliberate and is not reported as a leak.
EARLY_EXIT_KINDS = frozenset(('return', 'break', 'continue', 'goto'))

# CFG node kinds whose span covers a controlling condition. A control-flow graph
# node of one of these kinds spans only its test expression, not its body, so a
# reference to the resource inside such a node is the resource being tested.
BRANCH_KINDS = frozenset(('if', 'while-for', 'do-while', 'switch'))


def ids():
    return ('MISRA12_DIR_4.13', 'MISRA23_DIR_4.13', 'MISRA25_DIR_4.13', 'CPP_F074')


