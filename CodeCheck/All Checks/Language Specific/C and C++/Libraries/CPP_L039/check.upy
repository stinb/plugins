import re

from Modules import isFilePointer, refBeforeRef
from understand import CFNode, Ent, Ref


ERR1 = 'Use of pointer to closed FILE'


def ids():
    return ('MISRA12_22.6', 'MISRA23_22.6', 'MISRA25_22.6', 'CPP_L039')


