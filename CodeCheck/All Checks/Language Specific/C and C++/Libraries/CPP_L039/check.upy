    return {
        'MISRA12_22.6': '''Published Standards/MISRA C 2012/\
22.6 The value of a pointer to a FILE shall not be used after the associated \
stream has been closed (Partial)''',
        'MISRA23_22.6': '''Published Standards/MISRA C 2023/\
22.6 Use of Closed FILE Pointers (Partial)''',
        'MISRA25_22.6': '''Published Standards/MISRA C 2025/\
The value of a pointer to a FILE shall not be used after the associated \
stream has been closed (Partial)''',
        'CPP_L039': '''All Checks/Language Specific/C and C++/Libraries/\
Use of Closed FILE Pointers (Partial)''',
    }[id]


